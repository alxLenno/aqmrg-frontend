{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://aqmrg.pythonanywhere.com/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://aqmrg.pythonanywhere.com/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "/api"
  }
}
